---
import Base from "~/layouts/Base.astro";
import { safeJsonForScript } from "~/lib/safe-json";
import { getRoutedConcelhos, getLaresByConcelho, getConcelho, tipoLabel, valenciaLabel } from "~/lib/lares";

export async function getStaticPaths() {
  return getRoutedConcelhos().map((c) => ({
    params: { concelho: c.slug },
    props: { concelho: c },
  }));
}

const { concelho } = Astro.props;
const lares = getLaresByConcelho(concelho.slug);

const SITE = "https://www.precoslares.pt";
const url = `${SITE}/lares/${concelho.slug}`;

const ipssCount = lares.filter((l) => l.tipo === "ipss" || l.tipo === "misericordia").length;
const privadoCount = lares.filter((l) => l.tipo === "privado").length;
const comAcordoCount = lares.filter((l) => l.acordoSS).length;

const prices = lares
  .filter((l) => l.preco?.min != null && l.preco?.max != null)
  .map((l) => ({ min: l.preco!.min!, max: l.preco!.max! }));
const precoMin = prices.length ? Math.min(...prices.map((p) => p.min)) : null;
const precoMax = prices.length ? Math.max(...prices.map((p) => p.max)) : null;

const ld = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "CollectionPage",
      "@id": `${url}#page`,
      name: `Lares de idosos em ${concelho.nome}`,
      description: `Lares no concelho de ${concelho.nome}, com preços, tipo e acordo com a Segurança Social.`,
      inLanguage: "pt-PT",
      isPartOf: { "@id": `${SITE}#website` },
    },
    {
      "@type": "BreadcrumbList",
      itemListElement: [
        { "@type": "ListItem", position: 1, name: "Início", item: `${SITE}/` },
        { "@type": "ListItem", position: 2, name: "Lares", item: `${SITE}/lares` },
        { "@type": "ListItem", position: 3, name: concelho.nome },
      ],
    },
  ],
};

const titlePrefix = lares.length > 0
  ? `${lares.length} lar${lares.length === 1 ? "" : "es"} de idosos em ${concelho.nome}`
  : `Lares de idosos em ${concelho.nome}`;
---

<Base
  title={`${titlePrefix} — preços e diretório — precoslares.pt`}
  description={lares.length > 0
    ? `${lares.length} lares em ${concelho.nome}: ${ipssCount} IPSS/Misericórdia + ${privadoCount} privado${privadoCount === 1 ? "" : "s"}. ${precoMin && precoMax ? `Preços de €${precoMin} a €${precoMax}/mês.` : ""}`
    : `Lares de idosos no concelho de ${concelho.nome}. Diretório em construção; partilhe um preço anonimamente para nos ajudar a crescer.`}
  canonicalPath={`/lares/${concelho.slug}`}
>
  <script
    slot="head-jsonld"
    type="application/ld+json"
    set:html={safeJsonForScript(ld)}
  />

  <section class="max-w-3xl mx-auto">
    <nav class="text-xs text-ink-soft mb-3">
      <a href="/" class="no-underline hover:underline">Início</a>
      <span aria-hidden="true"> · </span>
      <a href="/lares" class="no-underline hover:underline">Lares</a>
      <span aria-hidden="true"> · </span>
      <span>{concelho.nome}</span>
    </nav>

    <p class="text-sm uppercase tracking-wider text-brand-500 font-semibold mb-2">
      Concelho · {concelho.distritoSlug.split("-").map((w) => w[0]?.toUpperCase() + w.slice(1)).join(" ")}
    </p>
    <h1 class="text-3xl sm:text-4xl font-bold mb-3">
      {lares.length > 0 ? `${lares.length} lar${lares.length === 1 ? "" : "es"} em ${concelho.nome}` : `Lares em ${concelho.nome}`}
    </h1>

    {lares.length > 0 ? (
      <p class="text-ink-muted mb-6">
        {[
          ipssCount > 0 && `${ipssCount} IPSS / Misericórdia${ipssCount === 1 ? "" : "s"}`,
          privadoCount > 0 && `${privadoCount} privado${privadoCount === 1 ? "" : "s"}`,
          comAcordoCount > 0 && `${comAcordoCount} com acordo SS`,
        ].filter(Boolean).join(" · ")}
        {precoMin && precoMax && (
          <>
            {" "}· preços de <strong>€{precoMin} a €{precoMax}/mês</strong>
          </>
        )}.
      </p>
    ) : (
      <div class="banner banner-info mb-6">
        <span>
          Ainda não temos lares confirmados em <strong>{concelho.nome}</strong>.
          Esta página existe porque é uma das pesquisas mais frequentes em Portugal —
          em breve teremos dados. Conhece um lar aqui? <a href={`mailto:gairifo@gmail.com?subject=${encodeURIComponent(`[precoslares] Adicionar lar em ${concelho.nome}`)}`}>Diga-nos</a>.
        </span>
      </div>
    )}

    {lares.length > 0 && (
      <>
        <div class="flex flex-wrap gap-2 mb-5" id="tipo-filters">
          <button class="chip chip-filter chip-active" data-tipo="todos">Todos ({lares.length})</button>
          {lares.some((l) => l.tipo === "ipss") && (
            <button class="chip chip-filter" data-tipo="ipss">IPSS ({lares.filter((l) => l.tipo === "ipss").length})</button>
          )}
          {lares.some((l) => l.tipo === "misericordia") && (
            <button class="chip chip-filter" data-tipo="misericordia">Misericórdia ({lares.filter((l) => l.tipo === "misericordia").length})</button>
          )}
          {lares.some((l) => l.tipo === "cooperativa") && (
            <button class="chip chip-filter" data-tipo="cooperativa">Cooperativa ({lares.filter((l) => l.tipo === "cooperativa").length})</button>
          )}
          {lares.some((l) => l.tipo === "privado") && (
            <button class="chip chip-filter" data-tipo="privado">Privado ({lares.filter((l) => l.tipo === "privado").length})</button>
          )}
        </div>

        <p id="filter-empty" class="text-sm text-ink-muted mb-4 hidden">Nenhum lar deste tipo neste concelho.</p>

        <div class="space-y-3 mb-10" id="lares-list">
          {lares.map((lar) => (
            <div class="bg-white border border-rule rounded-xl p-5 hover:border-brand-100 hover:shadow-sm transition" data-tipo={lar.tipo}>
              <a
                href={`/lares/${concelho.slug}/${lar.slug}`}
                class="no-underline"
              >
                <div class="flex items-start justify-between gap-3 mb-1">
                  <h2 class="text-lg font-bold text-ink leading-tight">{lar.nome}</h2>
                  <span class={`chip badge-elig-${lar.tipo === "privado" ? "possivel" : "provavel"} shrink-0`}>
                    {tipoLabel(lar.tipo)}
                  </span>
                </div>
                <p class="text-sm text-ink-muted mb-2">
                  {lar.valencias.map(valenciaLabel).join(" · ")}
                  {lar.freguesia && ` · ${lar.freguesia}`}
                </p>
                <div class="flex flex-wrap gap-3 text-xs mb-3">
                  {lar.acordoSS && (
                    <span class="text-brand-700 font-semibold">✓ Acordo SS</span>
                  )}
                  {lar.preco?.min != null && lar.preco?.max != null && (
                    <span class="tabular-nums">
                      €{lar.preco.min}–€{lar.preco.max}/mês
                      <span class="text-ink-soft">
                        {" "}({
                          lar.preco.source === "operator_published" ? "publicado" :
                          lar.preco.source === "user_reported" ? "reportado" :
                          "estimado"
                        })
                      </span>
                    </span>
                  )}
                  {lar.capacidade && (
                    <span class="text-ink-soft">{lar.capacidade} camas</span>
                  )}
                </div>
              </a>
              {(lar.telefone || lar.email) && (
                <div class="flex flex-wrap gap-2 pt-3 border-t border-rule">
                  {lar.telefone && (
                    <a href={`tel:${lar.telefone.replace(/\s/g, "")}`} class="inline-flex items-center gap-1.5 text-sm font-medium text-brand-600 bg-brand-50 rounded-lg px-3 py-1.5 no-underline hover:bg-brand-100 transition">
                      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                      Ligar
                    </a>
                  )}
                  {lar.email && (
                    <a href={`mailto:${lar.email}`} class="inline-flex items-center gap-1.5 text-sm font-medium text-ink-muted bg-slate-50 rounded-lg px-3 py-1.5 no-underline hover:bg-slate-100 transition">
                      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
                      Email
                    </a>
                  )}
                </div>
              )}
            </div>
          ))}
        </div>
      </>
    )}

    <section class="bg-brand-50 border border-brand-100 rounded-2xl p-5 mt-8">
      <h2 class="text-base font-bold mb-2">Vai escolher um lar em {concelho.nome}?</h2>
      <p class="text-sm text-ink-muted mb-3">
        Use a calculadora para perceber, em 90 segundos, quanto pagaria de facto após os apoios da Segurança Social
        (CSI, complemento por dependência, IRS Art. 84.º, ADSE).
      </p>
      <a href="/calculadora" class="btn-primary text-sm">Calcular os meus apoios →</a>
    </section>
  </section>

  <script>
    const filters = document.getElementById("tipo-filters");
    const list = document.getElementById("lares-list");
    const empty = document.getElementById("filter-empty");
    if (filters && list) {
      filters.addEventListener("click", (e) => {
        const btn = (e.target as HTMLElement).closest<HTMLButtonElement>("[data-tipo]");
        if (!btn) return;
        const tipo = btn.dataset.tipo!;
        filters.querySelectorAll(".chip-filter").forEach((b) => b.classList.remove("chip-active"));
        btn.classList.add("chip-active");
        let visible = 0;
        list.querySelectorAll<HTMLElement>("[data-tipo]").forEach((card) => {
          const show = tipo === "todos" || card.dataset.tipo === tipo;
          card.style.display = show ? "" : "none";
          if (show) visible++;
        });
        if (empty) empty.classList.toggle("hidden", visible > 0);
      });
    }
  </script>
</Base>
