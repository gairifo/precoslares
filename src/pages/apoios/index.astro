---
import Base from "~/layouts/Base.astro";

const apoios = [
  { slug: "complemento-dependencia", nome: "Complemento por Dependência", t: "Mensal, pago pela Segurança Social a pensionistas com 1.º ou 2.º grau de dependência reconhecidos pelo SVI. Pago em 14 mensalidades." },
  { slug: "csi", nome: "Complemento Solidário para Idosos (CSI)", t: "Apoio mensal a pensionistas com 66+ anos e baixos rendimentos. Inclui benefícios extra (medicamentos gratuitos, próteses, óculos, transportes)." },
  { slug: "erpi-acordo", nome: "Comparticipação SS para ERPI", t: "Vaga subsidiada num lar IPSS / Misericórdia. A SS paga uma parte; a família paga uma comparticipação proporcional ao rendimento." },
  { slug: "irs-art-84", nome: "IRS — Encargos com lares (Art. 84º)", t: "Dedução à coleta de 25% das despesas com lar / apoio domiciliário, com limite anual de €403,75." },
  { slug: "irs-art-87", nome: "IRS — Pessoa com deficiência (Art. 87º)", t: "Dedução fixa de €1 343 (2,5 × IAS) para grau de incapacidade ≥ 60% no atestado multiusos. €2 149 adicional para grau ≥ 90%." },
  { slug: "adse-iasfa-sad", nome: "ADSE / IASFA / SAD-PSP", t: "Comparticipação em lar / apoio domiciliário para beneficiários de subsistemas (função pública, militar, polícia)." },
  { slug: "apoios-municipais", nome: "Apoios municipais", t: "Subsídios próprios da Câmara Municipal para idosos dependentes. Frequentemente sub-reclamados." },
  { slug: "cuidador-informal", nome: "Subsídio do Cuidador Informal", t: "Pago ao cuidador familiar reconhecido. Apenas se o idoso permanecer em casa." },
];
---

<Base
  title="Glossário de apoios — precoslares.pt"
  description="Os 8 principais apoios sociais para idosos em Portugal, explicados em linguagem simples."
  canonicalPath="/apoios"
>
  <section class="max-w-3xl mx-auto">
    <p class="text-sm uppercase tracking-wider text-brand-500 font-semibold mb-2">Glossário</p>
    <h1 class="text-3xl sm:text-4xl font-bold mb-3">Os apoios sociais para idosos</h1>
    <p class="text-ink-muted mb-8">
      O sistema português oferece vários apoios — sociais, fiscais, em vagas comparticipadas, em formação. Cada apoio tem regras próprias.
      Em vez de os ler todos, use a <a href="/calculadora">calculadora</a>: ela aplica todas as regras de uma vez.
    </p>
    <div class="space-y-4">
      {apoios.map((a) => (
        <article class="bg-white border border-rule rounded-xl p-5">
          <h2 class="text-lg font-bold mb-1">{a.nome}</h2>
          <p class="text-sm text-ink-muted">{a.t}</p>
        </article>
      ))}
    </div>
  </section>
</Base>
