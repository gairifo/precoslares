---
import { getCollection, render } from "astro:content";
import Base from "~/layouts/Base.astro";
import { safeJsonForScript } from "~/lib/safe-json";

export async function getStaticPaths() {
  const entries = await getCollection("apoios");
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);

const SITE = "https://www.precoslares.pt";
const url = `${SITE}/apoios/${entry.id}`;

const articleLd = {
  "@type": "Article",
  "@id": `${url}#article`,
  headline: entry.data.h1,
  description: entry.data.description,
  inLanguage: "pt-PT",
  datePublished: entry.data.lastUpdated.toISOString(),
  dateModified: entry.data.lastUpdated.toISOString(),
  mainEntityOfPage: url,
  author: { "@id": `${SITE}#org` },
  publisher: { "@id": `${SITE}#org` },
};

const faqLd = {
  "@type": "FAQPage",
  "@id": `${url}#faq`,
  mainEntity: entry.data.faqs.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
};

const breadcrumbLd = {
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Início", item: `${SITE}/` },
    { "@type": "ListItem", position: 2, name: "Apoios", item: `${SITE}/apoios` },
    { "@type": "ListItem", position: 3, name: entry.data.h1 },
  ],
};

const graph = {
  "@context": "https://schema.org",
  "@graph": [articleLd, faqLd, breadcrumbLd],
};

const lastUpdatedFmt = entry.data.lastUpdated.toLocaleDateString("pt-PT", {
  day: "numeric",
  month: "long",
  year: "numeric",
});
---

<Base
  title={entry.data.title}
  description={entry.data.description}
  canonicalPath={`/apoios/${entry.id}`}
  bodyClass="page-apoio"
>
  <script
    slot="head-jsonld"
    type="application/ld+json"
    set:html={safeJsonForScript(graph)}
  />

  <article class="prose-content max-w-prose mx-auto text-ink">
    <nav class="text-xs text-ink-soft mb-4">
      <a href="/" class="no-underline hover:underline">Início</a>
      <span aria-hidden="true"> · </span>
      <a href="/apoios" class="no-underline hover:underline">Apoios</a>
      <span aria-hidden="true"> · </span>
      <span>{entry.data.h1}</span>
    </nav>

    <p class="text-xs uppercase tracking-wide text-brand-500 font-semibold mb-2">
      Guia · Atualizado em {lastUpdatedFmt} · {entry.data.readingMinutes} min de leitura · Valores de {entry.data.iasYear}
    </p>

    <h1 class="text-3xl sm:text-4xl font-bold mb-4 leading-tight">
      {entry.data.h1}
    </h1>

    <div class="bg-brand-50 border border-brand-100 rounded-xl p-5 mb-8 not-prose">
      <p class="text-sm uppercase tracking-wide text-brand-700 font-semibold mb-1">Em 30 segundos</p>
      <p class="text-base text-ink mb-3">{entry.data.agentSummary}</p>
      <a href="/calculadora" class="btn-primary text-sm">Ver quanto eu posso receber →</a>
    </div>

    <div class="prose-body">
      <Content />
    </div>

    <section class="mt-10 pt-6 border-t border-rule not-prose">
      <h2 class="text-xl font-bold mb-3">Perguntas frequentes</h2>
      <div class="space-y-4">
        {entry.data.faqs.map((f) => (
          <details class="bg-white border border-rule rounded-lg p-4">
            <summary class="font-semibold cursor-pointer">{f.q}</summary>
            <p class="text-sm text-ink-muted mt-2">{f.a}</p>
          </details>
        ))}
      </div>
    </section>

    <section class="mt-8 pt-6 border-t border-rule not-prose">
      <h2 class="text-lg font-bold mb-3">Fontes oficiais</h2>
      <ul class="space-y-2 text-sm text-ink-muted">
        {entry.data.sources.map((s) => (
          <li>
            <a href={s.canonical_url} target="_blank" rel="noopener nofollow" class="font-medium">
              {s.label}
            </a>
            {s.archive_url && (
              <>
                {" "}<span class="text-ink-soft">·</span>{" "}
                <a href={s.archive_url} target="_blank" rel="noopener nofollow" class="text-ink-soft text-xs">
                  arquivo
                </a>
              </>
            )}
          </li>
        ))}
      </ul>
    </section>

    <section class="mt-8 pt-6 border-t border-rule text-center not-prose">
      <p class="text-sm text-ink-muted mb-4">
        Esta página é informativa e não substitui aconselhamento profissional.
        Os valores apresentados são os em vigor para {entry.data.iasYear};
        confirme sempre com a Segurança Social ou um técnico de serviço social.
      </p>
      <a href="/calculadora" class="btn-primary">Calcular os meus apoios →</a>
    </section>

    <p class="mt-10 text-xs text-ink-soft text-center">
      Conteúdo disponibilizado sob licença <a href="https://creativecommons.org/licenses/by-sa/4.0/" target="_blank" rel="noopener">CC BY-SA 4.0</a>.
      Se encontrou um erro factual,
      <a href={`mailto:gairifo@gmail.com?subject=${encodeURIComponent(`[precoslares] Erro em /apoios/${entry.id}`)}`}>reporte aqui</a>.
    </p>
  </article>
</Base>

<style is:global>
  .prose-body p { @apply text-base text-ink mb-4 leading-relaxed; }
  .prose-body h2 { @apply text-2xl font-bold mt-10 mb-3 leading-tight; }
  .prose-body h3 { @apply text-lg font-bold mt-6 mb-2; }
  .prose-body ul { @apply list-disc pl-6 mb-4 space-y-1; }
  .prose-body ol { @apply list-decimal pl-6 mb-4 space-y-1; }
  .prose-body li { @apply text-base text-ink; }
  .prose-body strong { @apply font-semibold text-ink; }
  .prose-body table { @apply w-full text-sm border-collapse mb-6; }
  .prose-body table th { @apply text-left font-semibold border-b border-rule py-2 px-3 bg-brand-50; }
  .prose-body table td { @apply border-b border-rule py-2 px-3; }
  .prose-body blockquote {
    @apply border-l-4 border-brand-500 pl-4 my-4 text-ink-muted italic;
  }
  .prose-body code {
    @apply bg-slate-100 text-ink-muted text-sm px-1.5 py-0.5 rounded;
  }
  .prose-body a {
    @apply text-brand-500 underline underline-offset-2 decoration-brand-100 hover:decoration-brand-500;
  }
</style>
