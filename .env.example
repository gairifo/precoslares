# ── Build-time / client-exposed env (Astro astro:env schema) ────────────
# Optional. When unset, the Plausible analytics script is not emitted.
# Set to your Plausible site name (e.g. "precoslares.pt") on Vercel
# build environment to enable analytics in production.
PLAUSIBLE_DOMAIN=

# Optional. URL of the price-report intake endpoint. Wizard's "Partilhar
# este preço anonimamente" button is a noop when this is unset.
# Production: https://precoslares.pt/api/report
# Dev (pointing at the deployed function): same URL
REPORT_ENDPOINT=

# ── Server-side env (Vercel Edge Function: api/report.ts) ───────────────
# Required for the price-report email forwarding via Resend. Get an API
# key at https://resend.com (free tier: 100 emails/day, 3,000/month).
# Without this set, the function still accepts reports but logs them
# to Vercel function output instead of emailing.
RESEND_API_KEY=

# Optional. Defaults to gairifo@gmail.com.
REPORT_TO_EMAIL=

# Optional. Defaults to "Precoslares <onboarding@resend.dev>".
# After verifying precoslares.pt with Resend (DNS records), switch to a
# domain address like "Precoslares <reports@precoslares.pt>".
REPORT_FROM_EMAIL=
